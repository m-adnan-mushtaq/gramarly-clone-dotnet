<Window x:Class="WordOverlayProofreader.Overlay.OverlayWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:WordOverlayProofreader.Overlay" mc:Ignorable="d" Title="WordOverlayProofreader" Height="450" Width="800" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True" ShowInTaskbar="False" Loaded="Window_Loaded">
  <Grid>
    <Canvas x:Name="OverlayCanvas">
      <!-- Squiggles will be drawn here -->
    </Canvas>

    <!-- Popover for suggestions -->
    <Popup x:Name="SuggestionPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
      <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="12">
        <Border.Effect>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" />
        </Border.Effect>
        <StackPanel MinWidth="200">
          <TextBlock x:Name="ErrorTypeText" FontWeight="Bold" Margin="0,0,0,8" FontSize="12" Foreground="#333333" />
          <TextBlock x:Name="OriginalTextBlock" Text="Original:" FontSize="11" Foreground="#666666" Margin="0,0,0,2" />
          <TextBlock x:Name="OriginalText" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap" />
          <Separator Margin="0,0,0,8" />
          <TextBlock Text="Suggestion:" FontWeight="SemiBold" FontSize="11" Foreground="#666666" Margin="0,0,0,5" />
          <ItemsControl x:Name="SuggestionsList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Content="{Binding suggestion}" Click="ApplySuggestion_Click" Margin="0,3" Padding="10,6" HorizontalAlignment="Stretch" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="12">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Setter Property="Background" Value="#4CAF50"/>
                      <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="#45a049"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Content="Ignore" Click="Ignore_Click" Margin="0,8,0,0" Background="Transparent" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#666666" Padding="10,4" Cursor="Hand" FontSize="11" />
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</Window>